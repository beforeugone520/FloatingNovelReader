<Window x:Class="FloatingNovelReader.Views.BookshelfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="我的书架"
        Width="900" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部栏：标题 + 搜索 + 导入 + 设置 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="📚 我的书架" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <ComboBox x:Name="SortCombo" Width="120" Margin="6,0"
                          SelectionChanged="OnSortChanged"
                          SelectedIndex="0">
                    <ComboBoxItem Content="最近阅读"/>
                    <ComboBoxItem Content="导入时间"/>
                    <ComboBoxItem Content="书名"/>
                </ComboBox>
                <TextBox x:Name="SearchBox" Width="180" Margin="6,0" Padding="6,3"
                         TextChanged="OnSearchChanged" Tag="搜索书名..."/>
                <Button Content="导入" Padding="12,4" Margin="6,0" Click="OnImportClick"/>
                <Button Content="设置" Padding="12,4" Margin="6,0" Click="OnSettingsClick"/>
            </StackPanel>
        </DockPanel>

        <!-- 书籍网格 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BooksList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource BookCard}" Cursor="Hand"
                                MouseLeftButtonUp="OnBookClick" MouseRightButtonUp="OnBookRightClick"
                                Tag="{Binding}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{Binding CoverColor}" Margin="0" CornerRadius="6,6,0,0">
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextWrapping="Wrap" Margin="8"/>
                                </Border>
                                <StackPanel Grid.Row="1" Margin="6,4">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Author}" FontSize="11" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11" Foreground="Gray">
                                        <Run Text="{Binding TotalChapters, Mode=OneWay}"/><Run Text=" 章"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 空状态 -->
        <TextBlock x:Name="EmptyHint" Grid.Row="1" Text="📖 书架空空的，点击右上角「导入」添加你的第一本书吧"
                   FontSize="14" Foreground="Gray"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</Window>
